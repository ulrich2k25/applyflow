# PostgreSQL
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"

# Uniquement nécessaire pour `prisma migrate dev` en local
SHADOW_DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/applyflow_shadow?schema=public"

# Utiliser une longue valeur aléatoire en production
JWT_SECRET="replace-with-a-long-random-secret"

# Origine autorisée par CORS
FRONTEND_URL="http://localhost:3000"

# Serveur NestJS
PORT=3001

# Stockage local des documents
UPLOAD_DIR="./uploads"