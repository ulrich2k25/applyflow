# PostgreSQL
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"

# Uniquement nécessaire pour `prisma migrate dev` en local
SHADOW_DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/applyflow_shadow?schema=public"

# Utiliser une longue valeur aléatoire en production
JWT_SECRET="replace-with-a-long-random-secret"

# Origine autorisée par CORS
FRONTEND_URL="http://localhost:3000"

# Serveur NestJS
PORT=3001

# Stockage des documents : "local" en développement ou "cloudinary" en production
STORAGE_DRIVER="local"

# Utilisé uniquement avec STORAGE_DRIVER="local"
UPLOAD_DIR="./uploads"

# Utilisés uniquement avec STORAGE_DRIVER="cloudinary"
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"
